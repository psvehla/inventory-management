      "mcp__playwright__browser_console_messages",
      "Bash(lsof -ti:8001)",
      "Bash(mkdir:*)",
      "Bash(npx playwright:*)",
      "Bash(node -e \"require.resolve\\(''playwright''\\)\")",
      "Read(//usr/local/lib/**)",
      "Read(//Users/peter.svehla/.npm/**)",
      "Bash(npm init:*)",
      "Bash(node dark-mode-test.mjs)"
